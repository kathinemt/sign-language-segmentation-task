REF2="ts24" ANNOTATION_ID="a3228834"><ANNOTATION_VALUE>Die Katze, die den Vogel immer fressen will?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts24" TIME_SLOT_REF2="ts28" ANNOTATION_ID="a3228837"><ANNOTATION_VALUE>Das ist ein Film im Fernsehen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts35" ANNOTATION_ID="a3228838"><ANNOTATION_VALUE>Da sieht man zuerst ganz viele Häuser.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts44" ANNOTATION_ID="a3228839"><ANNOTATION_VALUE>Dann schwenkt die Kamera auf die Katze.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts44" TIME_SLOT_REF2="ts49" ANNOTATION_ID="a3228840"><ANNOTATION_VALUE>Sie sitzt am Fensterbrett und schaut durch ein Fernglas.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts54" ANNOTATION_ID="a3228843"><ANNOTATION_VALUE>Sie scheint etwas zu suchen.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts54" TIME_SLOT_REF2="ts62" ANNOTATION_ID="a3228847"><ANNOTATION_VALUE>Als sie nach oben schaut, erblickt sie einen Vogelkäfig.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts69" ANNOTATION_ID="a3228849"><ANNOTATION_VALUE>Darin sitzt ein gelber Vogel.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts79" ANNOTATION_ID="a3228850"><ANNOTATION_VALUE>Der Vogel schaut selbst auch durch ein Fernglas.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts88" ANNOTATION_ID="a3228853"><ANNOTATION_VALUE>Plötzlich entdeckt er die Katze und die beiden starren sich entsetzt an.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts88" TIME_SLOT_REF2="ts94" ANNOTATION_ID="a3228856"><ANNOTATION_VALUE>Die Katze denkt kurz nach.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts94" TIME_SLOT_REF2="ts98" ANNOTATION_ID="a3228859"><ANNOTATION_VALUE>Dann saust sie nach unten.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts109" ANNOTATION_ID="a3228888"><ANNOTATION_VALUE>Auf der anderen Straßenseite steht ein Hotel.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts119" ANNOTATION_ID="a3228892"><ANNOTATION_VALUE>Die Katze geht schnurstracks durch den Haupteingang hinein.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts127" ANNOTATION_ID="a3228893"><ANNOTATION_VALUE>Doch es klappt nicht, sie fliegt in hohem Bogen wieder raus.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts134" ANNOTATION_ID="a3228903"><ANNOTATION_VALUE>Der Pförtner wirft sie in hohem Bogen raus.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Translation_into_English_B" LINGUISTIC_TYPE_REF="L_text__coarser_granularity" PARTICIPANT="koe-07"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts1" TIME_SLOT_REF2="ts12" ANNOTATION_ID="a3257338"><ANNOTATION_VALUE>You know that cat and that yellow bird.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts12" TIME_SLOT_REF2="ts24" ANNOTATION_ID="a3257340"><ANNOTATION_VALUE>The cat that always wants to eat the bird?</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts24" TIME_SLOT_REF2="ts28" ANNOTATION_ID="a3257345"><ANNOTATION_VALUE>It’s a TV movie.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts28" TIME_SLOT_REF2="ts35" ANNOTATION_ID="a3257347"><ANNOTATION_VALUE>At first, you see a lot of houses.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts35" TIME_SLOT_REF2="ts44" ANNOTATION_ID="a3257352"><ANNOTATION_VALUE>Then the camera pans to the cat.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts44" TIME_SLOT_REF2="ts49" ANNOTATION_ID="a3257354"><ANNOTATION_VALUE>It sits on the windowsill and is watching the outside through some binoculars.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts49" TIME_SLOT_REF2="ts54" ANNOTATION_ID="a3257357"><ANNOTATION_VALUE>It seems to be looking for something.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts54" TIME_SLOT_REF2="ts62" ANNOTATION_ID="a3257358"><ANNOTATION_VALUE>As it looks up, it notices a bird cage.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts62" TIME_SLOT_REF2="ts69" ANNOTATION_ID="a3257361"><ANNOTATION_VALUE>In it, there’s a yellow bird.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts69" TIME_SLOT_REF2="ts79" ANNOTATION_ID="a3257363"><ANNOTATION_VALUE>The bird is also looking through binoculars.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts79" TIME_SLOT_REF2="ts88" ANNOTATION_ID="a3257367"><ANNOTATION_VALUE>It suddenly notices the cat and the both of them stare at each other in shock.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts88" TIME_SLOT_REF2="ts94" ANNOTATION_ID="a3257368"><ANNOTATION_VALUE>The cat thinks for a bit.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts94" TIME_SLOT_REF2="ts98" ANNOTATION_ID="a3257369"><ANNOTATION_VALUE>Then it rushes downstairs.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts98" TIME_SLOT_REF2="ts109" ANNOTATION_ID="a3257372"><ANNOTATION_VALUE>On the other side of the street, there’s a hotel.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts109" TIME_SLOT_REF2="ts119" ANNOTATION_ID="a3257373"><ANNOTATION_VALUE>The cat enters through the main entrance straightway.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts119" TIME_SLOT_REF2="ts127" ANNOTATION_ID="a3257377"><ANNOTATION_VALUE>But it doesn’t work, it gets sent flying out.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts127" TIME_SLOT_REF2="ts134" ANNOTATION_ID="a3257386"><ANNOTATION_VALUE>The doorman kicks it out.</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION></TIER><TIER TIER_ID="Lexem_Geb&#xE4;rde_r_B" LINGUISTIC_TYPE_REF="L_tokens_right_left__finer_granularity" PARTICIPANT="koe-07"><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts3" ANNOTATION_ID="a3269295_1"><ANNOTATION_VALUE>DU1*</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts4" TIME_SLOT_REF2="ts5" ANNOTATION_ID="a3269296_1"><ANNOTATION_VALUE>KENNEN1A</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts6" TIME_SLOT_REF2="ts7" ANNOTATION_ID="a3269652_1"><ANNOTATION_VALUE>KATZE3</ANNOTATION_VALUE></ALIGNABLE_ANNOTATION></ANNOTATION><ANNOTATION><ALIGNABLE_ANNOTATION TIME_SLOT_REF1="ts8" TIME_